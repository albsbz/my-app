{
  "compilerOptions": {
    "checkJs": false,
    "noImplicitAny": false,
    "jsx": "preserve",
    "paths": {
      "@/*": ["./*"],
      "@components/*": ["./app/_components/*"],
      "@hooks/*": ["./app/_hooks/*"],
      "@services/*": ["./app/_services/*"],
      "@utils/*": ["./app/_utils/*"],
      "@context/*": ["./app/_context/*"]
    }
  },
  "exclude": ["node_modules", ".next"]
}
